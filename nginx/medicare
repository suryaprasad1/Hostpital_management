upstream medicare_app {
    server 127.0.0.1:8000 fail_timeout=0;
}

server {
    listen 80;
    server_name 3.237.67.226;
    
    client_max_body_size 10M;

    # Access logs
    access_log /var/log/nginx/medicare_access.log;
    error_log /var/log/nginx/medicare_error.log;

    # Static files
    location /static/ {
        alias /home/ubuntu/Hostpital_management/staticfiles/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Media files
    location /media/ {
        alias /home/ubuntu/Hostpital_management/media/;
        expires 7d;
    }

    # Proxy to Gunicorn
    location / {
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host $http_host;
        proxy_redirect off;
        proxy_pass http://medicare_app;
    }
}
